# ============================================================
# .gitignore for Apple Disease Detection Project
# ============================================================

# Virtual Environment
venv/
env/
ENV/
.venv/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.installed.cfg
*.egg

# Distribution / packaging
build/
dist/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.manifest
*.spec

# IDE / Editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Jupyter Notebook
.ipynb_checkpoints

# Environment variables
.env
.env.local
*.env

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Logs
*.log
logs/

# Dataset (TOO LARGE for GitHub - download separately)
train/
test/
validation/

# Backup files
*.backup
apple_backup.py
*_backup.*
backup_old_models/

# Temporary files
*.tmp
*.temp
temp/
tmp/

# OS specific
.DS_Store
Thumbs.db
desktop.ini

# Output files (optional - keep these for reports)
# Uncomment if outputs are too large:
# output/

# Large model files (optional)
# Uncomment if .pkl files are >100MB:
# *.pkls